@startuml

title Nouveau Diagramme de classe

interface Appareils {
  + allumer()
  + eteindre()
}

class Lampe {
  - nom : String
  - allume : boolean
  + allumer()
  + eteindre()
}

class Hifi {
  - son : int
  + allumer()
  + eteindre()
}

class Television {
  - chaine : int
  + allumer()
  + eteindre()
}

class Telecommande {
  - appareils : List<Appareils>
  + Telecommande()
  + ajouterA(Appareils)
  + activerA(int)
  + desactiverA(int)
  + activerTout()
  + toString() : String
}


class AdapterCheminee{
  + c : Cheminee
}

class Cheminee {
  + changerIntensite(int)
  + getLumiere() : int
}

Telecommande "1" --> "*" Appareils : contrôle

Appareils <|.. Lampe
Appareils <|.. Hifi
Appareils <|.. Television
Appareils <|.. AdapterCheminee

AdapterCheminee --> Cheminee

@enduml
